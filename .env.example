#========= Auth Service DB =========
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_strong_password
AUTH_DB_NAME=auth_db
AUTH_DB_PORT=5432

#========= Forest Service DB =========
FOREST_DB_USER=forest_user
FOREST_DB_PASSWORD=forest_strong_password
FOREST_DB_NAME=forest_db
FOREST_DB_PORT=5433

#========= REDIS =========
REDIS_PORT=6379

#========= JWT =========
